# Local dev: Vite inlines these for the client bundle. In staging/prod, set the same names on the
# dashboard Deployment instead; the browser uses same-origin `/api` when `VITE_API_URL` is unset
# at build time, and TinyAuth URL is exposed via `<meta name="sitio:tinyauth-app-url">` from
# `process.env.VITE_TINYAUTH_APP_URL` on the server.
VITE_API_URL=http://localhost:3000/api
# VITE_TINYAUTH_APP_URL=https://tinyauth.artr.com.br
