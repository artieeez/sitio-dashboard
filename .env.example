# Base URL for the Nest API (must include `/api` global prefix).
# Backend default: http://localhost:3000 — dashboard dev server uses port 5173 to avoid clashing.
VITE_API_URL=http://localhost:3000/api

# Optional. When set, API 401 triggers full-page navigation to TinyAuth with `redirect_uri`
# (same host family as the dashboard; cookies for `.artr.com.br` can be sent with credentials).
# VITE_TINYAUTH_APP_URL=https://tinyauth.artr.com.br
